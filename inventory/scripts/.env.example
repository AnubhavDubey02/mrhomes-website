# ──────────────────────────────────────────────────────
# Mr Homes Inventory Pipeline — environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────

# OpenAI API key — required for GPT-4 Vision OCR extraction
OPENAI_API_KEY=sk-...

# OpenAI model to use for image extraction
# Recommended: gpt-4o (highest accuracy) | gpt-4-turbo (faster/cheaper)
OPENAI_MODEL=gpt-4o

# OCR backend selector
# Options:
#   tesseract — Local OCR via tesseract.js, no API key required (DEFAULT)
#   openai    — GPT-4 Vision via OpenAI API; falls back to tesseract if OPENAI_API_KEY is missing
#   mock      — Returns empty records; useful for testing pipeline logic without any OCR
OCR_BACKEND=tesseract

# Confidence threshold for Tesseract (0–100).
# Extractions below this score leave fields blank and set Review_Status=Needs Review.
OCR_CONFIDENCE_THRESHOLD=60
